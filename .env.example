# Exemple de configuration J.A.R.V.I.S.
# Copie ce fichier en .env puis remplis seulement les services que tu utilises.

assistant_name=J.A.R.V.I.S

# IA cloud
GEMINI_API_KEY=
XAI_API_KEY=
GROQ_API_KEY=

# Services web / media
BLAGUES_API_TOKEN=
YOUTUBE_API_KEY=
SERPAPI_API_KEY=
NASA_API_KEY=
EXTENSION_ACCESS_TOKEN=

# Ollama local
OLLAMA_ENABLED=false
OLLAMA_PREFER_LOCAL=false
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODELS=llama3.1:8b,llama3:8b,mistral:instruct

# Home Assistant
HA_URL=
HA_TOKEN=
HA_WEATHER_ENTITY=
HOME_LOCATION_NAME=

# Emby
EMBY_URL=
EMBY_API_KEY=
EMBY_USER_ID=
EMBY_USERNAME=

# Proxmox
PROXMOX_URL=
PROXMOX_TOKEN_ID=
PROXMOX_TOKEN_SECRET=
PROXMOX_VERIFY_SSL=false

# Dashboard / securite
DISCORD_OWNER_ID=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
JARVIS_SESSION_SECRET=
